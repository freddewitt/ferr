{
  "$schema": "https://schemas.tauri.app/config/capabilities/2",
  "identifier": "default",
  "description": "Default capabilities for ferr-app",
  "platforms": ["linux", "macOS", "windows"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:allow-execute",
    "shell:allow-spawn",
    "notification:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load"
  ]
}
